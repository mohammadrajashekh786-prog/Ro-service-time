{
  "expo": {
    "name": "RO Service Alert",
    "slug": "ro-service-app"
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#CC0000",
    "extra": {
      "eas": {
        "projectId": "0971e6c7-1e1d-407c-9908-f19b67905060"
      }
    },
    "android": {
      "package": "com.blueguard.roservicealert",
      "versionCode": 1,
      "permissions": [
        "VIBRATE",
        "CALL_PHONE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-notifications"
    ]
  }
}
